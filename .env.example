# ========================================
# TELEGRAM BOT CONFIGURATION
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ========================================
# AI SCRIPT GENERATION (Choose one)
# ========================================
# Groq (FREE - Recommended)
SCRIPT_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (Paid)
# SCRIPT_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here

# Anthropic (Paid)
# SCRIPT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ========================================
# TEXT-TO-SPEECH (Choose one)
# ========================================
# Edge TTS (FREE - Recommended)
TTS_PROVIDER=edge

# Google Cloud TTS (FREE tier available)
# TTS_PROVIDER=google
# GOOGLE_CREDENTIALS_PATH=config/credentials/google-tts.json
# GOOGLE_PROJECT_ID=your_project_id

# ElevenLabs (Paid)
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your_elevenlabs_key

# ========================================
# IMAGE GENERATION (Choose one)
# ========================================
# PiAPI (Recommended - $0.008/video)
IMAGE_PROVIDER=piapi
PIAPI_API_KEY=your_piapi_key_here

# Pollinations (FREE but unreliable)
# IMAGE_PROVIDER=pollinations

# HuggingFace (FREE with key)
# IMAGE_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=your_hf_key_here

# ========================================
# VIDEO SETTINGS
# ========================================
VIDEO_FORMAT=shorts
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_DURATION=60
ENABLE_SUBTITLES=false

# ========================================
# QUEUE SETTINGS
# ========================================
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# ENVIRONMENT
# ========================================
ENVIRONMENT=development
